# Dependencies
node_modules/

# Local-checkout symlinks to the eliza monorepo (machine-specific — recreate via setup, do not commit)
/plugins
/packages/core
/packages/shared
/packages/ui
/packages/contracts

# Build output
dist/
playwright-report/
test-results/
*.tsbuildinfo

# Convex (generated by `convex dev`) + downloaded self-host compose
convex/_generated/
/docker-compose.yml

# Env / secrets
.env
.env.*
!.env.example
.dev.vars

# OS
.DS_Store

# Tokenomics scripts: real operator config + payout/run manifests stay local.
# The committed config.example.json template is a different filename, so it is
# not matched by this rule.
scripts/tokenomics/config.json
scripts/tokenomics/*.manifest.json
