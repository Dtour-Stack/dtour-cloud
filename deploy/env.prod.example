# Copy to deploy/.env (gitignored) and fill in. Used by docker-compose.prod.yml
# and deploy.sh.

# Public domain — its DNS A/AAAA record must point at this droplet.
DOMAIN=detour.ninja

# Convex public origins, path-routed under the single domain. CLOUD = API +
# live-sync; SITE = HTTP actions. Must match the Caddyfile prefixes.
CONVEX_CLOUD_ORIGIN=https://detour.ninja/convex
CONVEX_SITE_ORIGIN=https://detour.ninja/convex-http

# Convex self-host instance identity. Generate the secret once:
#   openssl rand -hex 32
INSTANCE_NAME=dtour
INSTANCE_SECRET=

# Build-time URL baked into the frontend bundle — must equal CONVEX_CLOUD_ORIGIN.
VITE_CONVEX_URL=https://detour.ninja/convex
# Client-side Solana RPC for the $DTOUR balance read. Use a real provider
# (Helius/QuickNode/Triton) — public mainnet-beta 403s from browsers.
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Filled in automatically by deploy.sh after the backend's first start
# (generate_admin_key.sh). Needed to push the convex/ functions.
# CONVEX_SELF_HOSTED_ADMIN_KEY=

# Coding dashboard (E2B Firecracker sandbox terminal). Without this the
# coding-relay starts but tells clients it's unconfigured. Get a key at
# https://e2b.dev — open infra: https://github.com/e2b-dev/e2b
# (server-side only — never expose to the browser).
# E2B_API_KEY=   # or: E2B_API_KEY=e2b_… ./scripts/provision-e2b-production.sh
# Paid chat A/B routing (optional): ab | eliza_first | openrouter_first
# INFERENCE_ROUTE_MODE=ab
# Admin Detour AgentMail envs are Convex deployment envs, set after deploy:
#   bunx convex env set AGENTMAIL_API_KEY "am_..."
#   bunx convex env set AGENTMAIL_INBOX_ID "admin-detour@agentmail.to"
#   bunx convex env set AGENTMAIL_WEBHOOK_SECRET "whsec_..."
# Webhook URL: https://detour.ninja/convex-http/agentmail/webhook
# Optional custom E2B template (build via services/coding-relay/e2b-template/README.md).
# E2B_TEMPLATE=
# Max sandbox lifetime per session in ms (caps E2B cost). Default 15 min.
# CODING_SESSION_MS=900000
# SANDBOX_VCPU=2
# SANDBOX_RAM_GIB=0.5
